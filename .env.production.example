# Jidaar Device Management System - Production Environment
# Copy this to .env.production on the server and fill in the values

# Database (from cPanel > MySQL Databases)
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@localhost:3306 DB_NAME"

# NextAuth.js
NEXTAUTH_SECRET="GENERATE-A-RANDOM-SECRET-HERE"
NEXTAUTH_URL="http://YOUR_DOMAIN"

# S3 / File Storage (optional - skip if not using file attachments)
# S3_ENDPOINT="https://your-s3-endpoint"
# S3_BUCKET="jidaar-attachments"
# S3_ACCESS_KEY="your-access-key"
# S3_SECRET_KEY="your-secret-key"
# S3_REGION="us-east-1"

# Sentry (optional)
# SENTRY_DSN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
